# MySQL Access
MYSQL_ROOT_PASSWORD=your_root_password
DB_USER=springuser
DB_PASSWORD=your_app_password

# Security & Cloud
BCRYPT_PASSWORD=your_test_password
# AWS is optional; if keys are missing, the app will use the local secret below
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Local JWT Fallback (Required if not using AWS)
resourcemanager.jwt.secret=your_32_character_secret_here_for_local_testing